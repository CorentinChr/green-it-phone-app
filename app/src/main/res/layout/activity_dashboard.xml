<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/dashboard_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dashboard_title"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <!-- Contrôle 1 : fréquence de nettoyage des mails (jours entre nettoyages) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/interval_label"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/txt_interval_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/interval_example"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp" />

                <SeekBar
                    android:id="@+id/seekbar_clean_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="29" /> <!-- représente 1..30 jours -->

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Contrôle 2 : désabonnement newsletters (switch) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/unsubscribe_label"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_unsubscribe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Résumé de l'impact -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/impact_title"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_impact_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="-0.0 kg CO2e / an"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp" />

                <ProgressBar
                    android:id="@+id/progressImpact"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="0"
                    android:max="100"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/txt_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/simulation_note"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Nouveaux contrôles de catégories (achats matériel, services) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Personnaliser les catégories"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Achats matériels : nombre d'appareils / an (0..10) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Achats matériels (appareils / an)"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/txt_hardware_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 appareils / an"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />

                <SeekBar
                    android:id="@+id/seekbar_hardware"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10"
                    android:layout_marginTop="4dp" />

                <!-- Services / Streaming : heures de streaming par semaine + qualité -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Streaming (heures / semaine)"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/txt_services_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 h / semaine"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />

                <SeekBar
                    android:id="@+id/seekbar_services"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="40"
                    android:layout_marginTop="4dp" />

                <!-- Choix de la qualité (SD/HD/UHD) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Qualité vidéo"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp" />

                <Spinner
                    android:id="@+id/spinner_quality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Diagramme des émissions par catégorie -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Répartition par catégorie"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChartCategories"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>

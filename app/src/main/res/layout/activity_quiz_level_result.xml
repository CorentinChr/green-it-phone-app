<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/green_background">

    <TextView
        android:id="@+id/level_result_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Résultat du quiz de test"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/level_result_score"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Score : 0 / 10"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/level_result_level"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Niveau : Débutant"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/level_result_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ton profil est enregistré. Tu peux maintenant accéder aux autres écrans."
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/level_result_back_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Retour à l'accueil" />

</LinearLayout>


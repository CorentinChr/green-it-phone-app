<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SAE6_APP" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colors -->
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/green_light</item>
        <item name="android:windowBackground">@color/green_background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Toolbar / Material components -->
        <item name="materialCardViewStyle">@style/Widget.MaterialComponents.CardView</item>
    </style>

    <style name="MyButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_primary</item>
        <!-- optionnel : ajuster backgroundTint si nécessaire -->
        <!-- <item name="backgroundTint">@color/white</item> -->
    </style>


    <style name="Theme.SAE6_APP" parent="Base.Theme.SAE6_APP" >
        <item name="materialButtonStyle">@style/MyButton</item>
    </style>
</resources>